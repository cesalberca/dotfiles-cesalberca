#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${1:-}" ]]; then
  echo "Usage: 3d-screenshot <screenshot-file>" >&2
  exit 1
fi

screenshot="$1"
base_name=$(basename "$screenshot" | cut -f 1 -d '.')
final="${base_name}_3d.png"

magick "$screenshot" \
  -alpha Set -virtual-pixel transparent \
  -distort Perspective '0,0 0,0  987,0 987,70  987,810 987,720  0,810 0,810' \
  "$final"

echo "Final image saved as $final"
